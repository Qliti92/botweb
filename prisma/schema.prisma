generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("admins")
}

model ChatSession {
  id        String        @id @default(cuid())
  status    SessionStatus @default(ACTIVE)
  state     String        @default("{}")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  messages  ChatMessage[]

  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(cuid())
  sessionId String      @map("session_id")
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sender    Sender
  content   String
  metadata  String?
  createdAt DateTime    @default(now()) @map("created_at")

  @@map("chat_messages")
}

model ConversationFlow {
  id                String      @id @default(cuid())
  flowKey           String      @unique @map("flow_key")
  title             String
  triggerKeyword    String?     @map("trigger_keyword")
  botMessage        String      @map("bot_message")
  expectedInputType String?     @map("expected_input_type")
  nextFlowKey       String?     @map("next_flow_key")
  actionType        ActionType? @map("action_type")
  apiId             String?     @map("api_id")
  api               ApiConfig?  @relation(fields: [apiId], references: [id])
  isActive          Boolean     @default(true) @map("is_active")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  @@map("conversation_flows")
}

model ApiConfig {
  id          String             @id @default(cuid())
  name        String
  key         String             @unique
  endpoint    String
  method      HttpMethod         @default(POST)
  headers     String             @default("{}")
  bodySample  String             @default("{}") @map("body_sample")
  description String?
  isActive    Boolean            @default(true) @map("is_active")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  flows       ConversationFlow[]
  logs        ApiLog[]

  @@map("api_configs")
}

model ApiLog {
  id         String    @id @default(cuid())
  apiId      String?   @map("api_id")
  api        ApiConfig? @relation(fields: [apiId], references: [id], onDelete: SetNull)
  sessionId  String?   @map("session_id")
  request    String
  response   String?
  statusCode Int?      @map("status_code")
  error      String?
  createdAt  DateTime  @default(now()) @map("created_at")

  @@map("api_logs")
}

model ShortLink {
  id          String   @id @default(cuid())
  code        String   @unique
  originalUrl String   @map("original_url")
  title       String?
  clickCount  Int      @default(0) @map("click_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("short_links")
}

model AppNotice {
  id              String   @id @default(cuid())
  title           String
  message         String
  displaySeconds  Int      @default(10) @map("display_seconds")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("app_notices")
}

enum Sender {
  USER
  BOT
  SYSTEM
}

enum SessionStatus {
  ACTIVE
  CLOSED
}

enum ActionType {
  CHECK_PHONE
  REGISTER_USER
  LOGIN_USER
  SHOW_MENU
  CONVERT_LINK
  API_CALL
  STATIC_MESSAGE
}

enum HttpMethod {
  GET
  POST
}
